# ==================================================
# 🔧 HÀM HỖ TRỢ LƯU/ĐỌC DỮ LIỆU
# ==================================================
def doc_file_json(duong_dan, mac_dinh):
    if not os.path.exists(duong_dan):
        return mac_dinh
    try:
        with open(duong_dan, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return mac_dinh

def luu_file_json(duong_dan, du_lieu):
    with open(duong_dan, "w", encoding="utf-8") as f:
        json.dump(du_lieu, f, ensure_ascii=False, indent=2)

# Tải dữ liệu khi khởi động
DANH_SACH_ADMIN: list = doc_file_json(FILE_ADMIN, [str(CHU_SO_HUU)])
DU_LIEU_NGUOI_DUNG: dict = doc_file_json(FILE_NGUOI_DUNG, {})

if str(CHU_SO_HUU) not in DANH_SACH_ADMIN:
    DANH_SACH_ADMIN.append(str(CHU_SO_HUU))

def la_admin(uid: int) -> bool:
    return str(uid) in DANH_SACH_ADMIN

bot = telebot.TeleBot(TOKEN, parse_mode=None)

# ==================================================
# 📝 GHI LOG & THÔNG BÁO — FORWARD FILE VÀO NHÓM
# ==================================================
def ghi_log_va_thong_bao(message, noi_dung_them=""):
    uid   = message.from_user.id
    ten   = f"{message.from_user.first_name} {message.from_user.last_name or ''}".strip()
    uname = f"@{message.from_user.username or 'khong_co'}"
    thoi_gian = datetime.now().strftime("%d/%m/%Y %H:%M:%S")
    loai_chat = "👥 NHÓM" if message.chat.type in ["group", "supergroup"] else "👤 RIÊNG"
    ten_nhom  = f" | Nhóm: {message.chat.title}" if loai_chat == "👥 NHÓM" else ""

    # Mô tả loại nội dung — KHÔNG in file_id nữa vì sẽ forward trực tiếp
    content_map = {
        "text":      lambda m: f"📝 Nội dung: {m.text}",
        "photo":     lambda m: "🖼️ ẢNH",
        "sticker":   lambda m: f"🎯 STICKER | Emoji: {m.sticker.emoji}",
        "animation": lambda m: "🎬 GIF",
        "video":     lambda m: "📹 VIDEO",
        "document":  lambda m: f"📄 TẬP TIN | Tên: {m.document.file_name}",
        "audio":     lambda m: "🎵 AUDIO",
        "voice":     lambda m: "🎙️ VOICE",
    }
    noi_dung = content_map.get(
        message.content_type,
        lambda m: f"🔹 Loại: {m.content_type.upper()}"
    )(message)

    log_text = (
        f"[{thoi_gian}] {loai_chat}{ten_nhom}\n"
        f"👤 ID: {uid} | Tên: {ten} | {uname}\n"
        f"{noi_dung} {noi_dung_them}"
    )

    # ── Ghi file log ──────────────────────────────
    try:
        with open(FILE_LOG, "a", encoding="utf-8") as f:
            f.write(log_text + "\n")
    except OSError as e:
        print(f"[LOG ERROR] {e}")

    # ── Gửi text info đến từng admin ──────────────
    for admin_id in DANH_SACH_ADMIN:
        try:
            bot.send_message(int(admin_id), log_text)
        except Exception:
            pass

    # ── Gửi vào NHOM_LOG ──────────────────────────
    try:
        # 1. Gửi dòng thông tin trước
        bot.send_message(NHOM_LOG, log_text)

        # 2. Nếu là media/file → chuyển tiếp tin nhắn gốc
        if message.content_type != "text":
            bot.forward_message(
                chat_id      = NHOM_LOG,
                from_chat_id = message.chat.id,
                message_id   = message.message_id,
            )
    except Exception as e:
        print(f"[FORWARD ERROR] {e}")

# ==================================================
# 📋 QUẢN LÝ ADMIN
# ==================================================
@bot.message_handler(commands=["themadmin"])
def them_admin(message):
    if not la_admin(message.from_user.id):
        return bot.reply_to(message, "❌ Bạn không có quyền!")
    parts = message.text.split()
    if len(parts) < 2:
        return bot.reply_to(message, "⚠️ Dùng: /themadmin [ID_nguoi_dung]")
    id_them = parts[1]
    if id_them not in DANH_SACH_ADMIN:
        DANH_SACH_ADMIN.append(id_them)
        luu_file_json(FILE_ADMIN, DANH_SACH_ADMIN)
        bot.reply_to(message, f"✅ Đã thêm admin ID: {id_them}")
    else:
        bot.reply_to(message, "⚠️ Người này đã là admin!")

@bot.message_handler(commands=["xoaadmin"])
def xoa_admin(message):
    if message.from_user.id != CHU_SO_HUU:
        return bot.reply_to(message, "❌ Chỉ chủ sở hữu mới xóa được admin!")
    parts = message.text.split()
    if len(parts) < 2:
        return bot.reply_to(message, "⚠️ Dùng: /xoaadmin [ID_nguoi_dung]")
    id_xoa = parts[1]
    if id_xoa in DANH_SACH_ADMIN and id_xoa != str(CHU_SO_HUU):
        DANH_SACH_ADMIN.remove(id_xoa)
        luu_file_json(FILE_ADMIN, DANH_SACH_ADMIN)
        bot.reply_to(message, f"✅ Đã xóa admin ID: {id_xoa}")
    else:
        bot.reply_to(message, "❌ Không tồn tại hoặc không thể xóa chủ sở hữu!")

@bot.message_handler(commands=["dsadmin"])
def ds_admin(message):
    if not la_admin(message.from_user.id):
        return bot.reply_to(message, "❌ Không có quyền!")
    text = "👑 DANH SÁCH ADMIN:\n" + "\n".join(
        f"{idx}. {ad}" for idx, ad in enumerate(DANH_SACH_ADMIN, 1)
    )
    bot.reply_to(message, text)

