# 🔄 TỰ ĐỘNG KHỞI ĐỘNG LẠI KHI LỖI
# ==================================================
def chay_bot_khong_ngung():
    while True:
        try:
            print("🤖 BOT ĐANG CHẠY...")
            bot.polling(none_stop=True, interval=3, timeout=60, skip_pending=True)
        except Exception as e:
            print(f"⚠️ LỖI: {e} | Khởi động lại sau 5s...")
            time.sleep(5)

if __name__ == "__main__":
    chay_bot_khong_ngung()