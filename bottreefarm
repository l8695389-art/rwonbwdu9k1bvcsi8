    bot.send_photo(
        message.chat.id,
        LINK_ANH,
        caption=(
            "👋 Chào bạn! Chào mừng đến với Tree Farm 🌾\n\n"
            "Trồng trọt, làm nhiệm vụ mỗi ngày và tích xu đổi thưởng.\n"
            "Mời bạn bè, leo bảng xếp hạng và rút kim cương khi đủ điều kiện."
        ),
        reply_markup=keyboard,
    )

# ==================================================
# 📢 GỬI THÔNG BÁO BROADCAST
# ==================================================
@bot.message_handler(commands=["gui"])
def gui_thong_bao(message):
    if not la_admin(message.from_user.id):
        return
    reply = message.reply_to_message
    if not reply:
        return bot.reply_to(message, "⚠️ Trả lời tin nhắn cần gửi kèm lệnh /gui")

    thanh_cong = that_bai = 0
    bot.reply_to(message, "⏳ Đang gửi thông báo...")
    for uid in DU_LIEU_NGUOI_DUNG.keys():
        try:
            bot.copy_message(int(uid), message.chat.id, reply.message_id)
            thanh_cong += 1
        except Exception:
            that_bai += 1
        time.sleep(0.05)

    bot.reply_to(message, f"✅ Hoàn tất!\nThành công: {thanh_cong}\nThất bại: {that_bai}")

# ==================================================
# 🛡️ BẮT TẤT CẢ TIN NHẮN ĐỂ GHI LOG & FORWARD
# ==================================================
@bot.message_handler(content_types=[
    "text", "photo", "sticker", "animation",
    "video", "document", "audio", "voice"
])
def xu_ly_tat_ca_tin_nhan(message):
    if message.content_type == "text" and message.text and message.text.startswith("/"):
        return
    ghi_log_va_thong_bao(message)

