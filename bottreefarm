    uid = str(message.from_user.id)
    if uid not in DU_LIEU_NGUOI_DUNG:
        DU_LIEU_NGUOI_DUNG[uid] = {
            "ten": f"{message.from_user.first_name} {message.from_user.last_name or ''}".strip(),
            "username":     message.from_user.username,
            "ngay_tham_gia": datetime.now().strftime("%d/%m/%Y %H:%M"),
            "coin": 0,
            "gem":  0,
        }
        luu_file_json(FILE_NGUOI_DUNG, DU_LIEU_NGUOI_DUNG)
